@model ShopSphereMVC.Models.LoginRequest

<h2>Login</h2>

<form method="post">

    <input asp-for="Email"
           class="form-control"
           placeholder="Email" />

    <br />

    <input asp-for="Password"
           type="password"
           class="form-control"
           placeholder="Password" />

    <br />

    <button type="submit" class="btn btn-primary"> Login </button>

</form>

<p style="color:red">
    @ViewBag.Error
</p>