@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2 class="mb-4">Admin Dashboard</h2>

<div class="row">

    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h5>Total Products</h5>
                <h2>@ViewBag.TotalProducts</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h5>Total Categories</h5>
                <h2>@ViewBag.TotalCategories</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h5>Total Orders</h5>
                <h2>@ViewBag.TotalOrders</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h5>Total Revenue</h5>
                <h2>₹@ViewBag.TotalRevenue</h2>
            </div>
        </div>
    </div>

</div>