@model List<ShopSphereMVC.Models.WishlistItem>

<h2>My Wishlist ❤️</h2>

<table class="table">

    <tr>
        <th>Image</th>
        <th>Name</th>
        <th>Price</th>
        <th>Action</th>
    </tr>

    @foreach(var item in Model)
    {
        <tr>

            <td>
                <img src="@item.Product.ImageUrl"
                     width="80" />
            </td>

            <td>
                @item.Product.Name
            </td>

            <td>
                ₹@item.Product.Price
            </td>

            <td>

                <form asp-action="MoveToCart"
                      method="post"
                      style="display:inline;">

                    <input type="hidden"
                           name="productId"
                           value="@item.ProductId" />

                    <button type="submit" class="btn btn-success btn-sm">
                        Move To Cart
                    </button>

                </form>

                <a asp-action="Remove"
                   asp-route-productId="@item.ProductId"
                   class="btn btn-danger btn-sm">
                    Remove
                </a>

            </td>

        </tr>
    }

</table>